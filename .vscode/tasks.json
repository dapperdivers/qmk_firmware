{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "QMK: Compile (skeletyl/barediver)",
            "type": "shell",
            "command": "qmk compile -kb bastardkb/skeletyl/promicro -km barediver",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "QMK: Flash (skeletyl/barediver)",
            "type": "shell",
            "command": "qmk flash -kb bastardkb/skeletyl/promicro -km barediver",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "QMK: Regenerate compile_commands.json",
            "type": "shell",
            "command": "qmk compile -kb bastardkb/skeletyl/promicro -km barediver --compiledb",
            "problemMatcher": []
        },
        {
            "label": "QMK: Draw keymap diagram (skeletyl/barediver)",
            "type": "shell",
            "command": "qmk c2json -kb bastardkb/skeletyl/promicro -km barediver -o docs/barediver.json && keymap parse -q docs/barediver.json -l Base Tap Button Nav Mouse Media Num Sym Fun Win Arrows > docs/barediver.keymap.yaml && keymap draw docs/barediver.keymap.yaml > docs/barediver.svg && rsvg-convert -z 1.5 -b white docs/barediver.svg -o docs/barediver.png",
            "options": {
                "cwd": "${workspaceFolder}/keyboards/bastardkb/skeletyl/keymaps/barediver"
            },
            "problemMatcher": []
        }
    ]
}
